local function animateRowIn(row, delayTime)
	local baseHeight = ROW_HEIGHT
	row.Position = UDim2.new(0, 20, 0, 0)
	row.BackgroundTransparency = 1
	for _, child in ipairs(row:GetChildren()) do
		if child:IsA("TextLabel") then child.TextTransparency = 1 end
		if child:IsA("ImageLabel") then child.ImageTransparency = 1 end
	end

	task.delay(delayTime, function()
		if not row.Parent then return end
		TweenService:Create(row, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Position = UDim2.new(0, 0, 0, 0),
			BackgroundTransparency = 0.15,
			Size = UDim2.new(1, 0, 0, baseHeight),
		}):Play()
		for _, child in ipairs(row:GetChildren()) do
			if child:IsA("TextLabel") then
				TweenService:Create(child, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
			elseif child:IsA("ImageLabel") then
				TweenService:Create(child, TweenInfo.new(0.3), {ImageTransparency = 0}):Play()
			end
		end
	end)
end

-- ===================== REFRESH LIST COM FILTRO =====================
local currentSearchFilter = ""

local function refreshList(filterText)
	filterText = filterText or currentSearchFilter
	currentSearchFilter = filterText

	for _, child in ipairs(container:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end

	local playersList = Players:GetPlayers()
	table.sort(playersList, function(a, b)
		return a.DisplayName:lower() < b.DisplayName:lower()
	end)

	-- Aplica filtro de pesquisa
	local filteredList = {}
	local searchLower = filterText:lower():gsub("^%s+", ""):gsub("%s+$", "")

	for _, plr in ipairs(playersList) do
		if searchLower == "" then
			table.insert(filteredList, plr)
		else
			local displayNameLower = plr.DisplayName:lower()
			local userNameLower = plr.Name:lower()
			if displayNameLower:find(searchLower, 1, true) or userNameLower:find(searchLower, 1, true) then
				table.insert(filteredList, plr)
			end
		end
	end

	for i, plr in ipairs(filteredList) do
		local row = createPlayerRow(plr, i)
		animateRowIn(row, (i - 1) * 0.06)
	end

	title.Text = ("JOGADORES (%d)"):format(#filteredList)
end

