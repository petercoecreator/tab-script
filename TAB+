local waterPlatform = create("Part", {
    Name = "SpeedGUI_WaterPlatform",
    Anchored = true,
    CanCollide = true,
    Transparency = 1,
    Size = Vector3.new(10, 1.5, 10),
    Material = Enum.Material.SmoothPlastic,
    CanQuery = false,
})

local waterConnection = nil

local function isWaterHit(result)
    if not result then return false end
    -- Verifica se o material da superfície atingida é água
    if result.Material == Enum.Material.Water then return true end
    -- Verifica se a instância atingida tem "water" no nome
    local inst = result.Instance
    if inst and inst.Name:lower():find("water") then return true end
    return false
end

local function setWaterOnWater(state)
    waterEnabled = state
    setWaterVisual(state)

    if waterConnection then
        waterConnection:Disconnect()
        waterConnection = nil
    end

    if state then
        waterPlatform.Parent = workspace
        -- Stepped roda antes da simulação física do frame, evitando que o
        -- personagem afunde por um instante antes da plataforma se ajustar.
        waterConnection = RunService.Stepped:Connect(function()
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            local raycastParams = RaycastParams.new()
            raycastParams.FilterType = Enum.RaycastFilterType.Exclude
            raycastParams.FilterDescendantsInstances = { char, waterPlatform }
            raycastParams.IgnoreWater = false

            -- Raycast para baixo a partir do HRP
            local origin = hrp.Position
            local result = workspace:Raycast(origin, Vector3.new(0, -20, 0), raycastParams)

            if isWaterHit(result) then
                -- Posiciona a plataforma na superfície da água
                waterPlatform.Size = Vector3.new(10, 1.5, 10)
                waterPlatform.CFrame = CFrame.new(hrp.Position.X, result.Position.Y + 0.75, hrp.Position.Z)
            else
                -- Esconde a plataforma quando não está sobre água
                waterPlatform.CFrame = CFrame.new(0, -2000, 0)
            end
        end)
    else
        waterPlatform.Parent = nil
    end
end

