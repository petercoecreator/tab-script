local function loadAvatarThumbnail(imageObject, userId, thumbnailType, thumbnailSize)
	task.spawn(function()
		for attempt = 1, 3 do
			local ok, content = pcall(function()
				return Players:GetUserThumbnailAsync(userId, thumbnailType, thumbnailSize)
			end)
			if ok and content and imageObject.Parent then
				imageObject.Image = content
				return
			end
			task.wait(0.5 * attempt)
		end
	end)
end

