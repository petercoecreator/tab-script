-- ============ REUSABLE: TOGGLE SWITCH ============
local function createToggle(parent, position)
    local bg = create("Frame", {
        Parent = parent,
        Size = UDim2.new(0, 44, 0, 24),
        Position = position,
        AnchorPoint = Vector2.new(1, 0.5),
        BackgroundColor3 = CONFIG.Switch,
    }, {
        create("UICorner", { CornerRadius = UDim.new(1, 0) }),
    })

    local dot = create("Frame", {
        Parent = bg,
        Size = UDim2.new(0, 18, 0, 18),
        Position = UDim2.new(0, 3, 0.5, -9),
        BackgroundColor3 = Color3.fromRGB(235, 235, 240),
    }, {
        create("UICorner", { CornerRadius = UDim.new(1, 0) }),
    })

    local button = create("TextButton", {
        Parent = bg,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
    })

    button.MouseButton1Down:Connect(function()
        playClick()
    end)

    local function setVisual(state)
        if state then
            tween(bg, { BackgroundColor3 = CONFIG.Accent }, 0.18)
            tween(dot, { Position = UDim2.new(1, -21, 0.5, -9) }, 0.18)
        else
            tween(bg, { BackgroundColor3 = CONFIG.Switch }, 0.18)
            tween(dot, { Position = UDim2.new(0, 3, 0.5, -9) }, 0.18)
        end
    end

    return button, setVisual
end

