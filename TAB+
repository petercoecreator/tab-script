-- ===================== LEADERSTATS HELPERS =====================

local function formatStatValue(valueObj)
	if valueObj:IsA("IntValue") or valueObj:IsA("NumberValue") then
		local lname = valueObj.Name:lower()
		if lname:find("time") or lname:find("tempo") then
			local total = math.floor(valueObj.Value)
			local mins = math.floor(total / 60)
			local secs = total % 60
			return string.format("%02d:%02d", mins, secs)
		end
		return tostring(valueObj.Value)
	elseif valueObj:IsA("StringValue") then
		return valueObj.Value
	elseif valueObj:IsA("BoolValue") then
		return valueObj.Value and "Sim" or "Nao"
	end
	return tostring(valueObj.Value)
end

local function getLeaderstats(plr)
	return plr:FindFirstChild("leaderstats")
end

local function getPrimaryStat(plr)
	local ls = getLeaderstats(plr)
	if not ls then return nil end
	for _, child in ipairs(ls:GetChildren()) do
		if child:IsA("ValueBase") then
			return child
		end
	end
	return nil
end

