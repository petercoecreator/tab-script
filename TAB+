-- ============ REUSABLE: SLIDER ============
local function createSlider(parent, yPos, minVal, maxVal, defaultVal, labelText)
    local sliderLabel = create("TextLabel", {
        Parent = parent,
        Size = UDim2.new(1, -28, 0, 16),
        Position = UDim2.new(0, 14, 0, yPos),
        BackgroundTransparency = 1,
        Text = labelText .. defaultVal,
        TextColor3 = CONFIG.SubText,
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local sliderBarBG = create("Frame", {
        Parent = parent,
        Size = UDim2.new(1, -28, 0, 8),
        Position = UDim2.new(0, 14, 0, yPos + 26),
        BackgroundColor3 = CONFIG.Switch,
    }, {
        create("UICorner", { CornerRadius = UDim.new(1, 0) }),
    })

    local function valToAlpha(val)
        return (val - minVal) / (maxVal - minVal)
    end

    local sliderFill = create("Frame", {
        Parent = sliderBarBG,
        Size = UDim2.new(valToAlpha(defaultVal), 0, 1, 0),
        BackgroundColor3 = CONFIG.Accent,
    }, {
        create("UICorner", { CornerRadius = UDim.new(1, 0) }),
        create("UIGradient", {
            Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, CONFIG.Accent),
                ColorSequenceKeypoint.new(1, CONFIG.AccentLight),
            }),
        }),
    })

    local sliderKnob = create("Frame", {
        Parent = sliderBarBG,
        Size = UDim2.new(0, 14, 0, 14),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(valToAlpha(defaultVal), 0, 0.5, 0),
        BackgroundColor3 = Color3.new(1, 1, 1),
        ZIndex = 5,
    }, {
        create("UICorner", { CornerRadius = UDim.new(1, 0) }),
        create("UIStroke", { Color = CONFIG.Accent, Thickness = 2 }),
    })

    local sliderInput = create("TextButton", {
        Parent = sliderBarBG,
        Size = UDim2.new(1, 0, 1, 20),
        Position = UDim2.new(0, 0, 0.5, -10),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 6,
    })

    create("TextLabel", {
        Parent = parent,
        Size = UDim2.new(1, -28, 0, 14),
        Position = UDim2.new(0, 14, 0, yPos + 44),
        BackgroundTransparency = 1,
        Text = minVal .. "                                              " .. maxVal,
        TextColor3 = CONFIG.SubText,
        Font = Enum.Font.Gotham,
        TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    return {
        Label = sliderLabel,
        BarBG = sliderBarBG,
        Fill = sliderFill,
        Knob = sliderKnob,
        Input = sliderInput,
        valToAlpha = valToAlpha,
        minVal = minVal,
        maxVal = maxVal,
    }
end

