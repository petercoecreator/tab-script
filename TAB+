notifAvatar.Size = UDim2.new(0, 40, 0, 40)
notifAvatar.BackgroundColor3 = ROW_COLOR
notifAvatar.ZIndex = 40
notifAvatar.Parent = notifToast

local notifAvatarCorner = Instance.new("UICorner")
notifAvatarCorner.CornerRadius = UDim.new(1, 0)
notifAvatarCorner.Parent = notifAvatar

local notifText = Instance.new("TextLabel")
notifText.Position = UDim2.new(0, 60, 0, 0)
notifText.Size = UDim2.new(1, -70, 1, 0)
notifText.BackgroundTransparency = 1
notifText.Font = Enum.Font.Gotham
notifText.TextSize = 14
notifText.TextWrapped = true
notifText.TextColor3 = Color3.fromRGB(255, 255, 255)
notifText.TextXAlignment = Enum.TextXAlignment.Left
notifText.Text = ""
notifText.ZIndex = 40
notifText.Parent = notifToast

local notifTweening = false

local function showFriendNotification(targetPlayer, eventType)
	if notifTweening then task.wait(0.6) end
	notifTweening = true

	local isPositive = (eventType == "join" or eventType == "friended")
	local accentColor = isPositive and Color3.fromRGB(90, 220, 130) or Color3.fromRGB(230, 110, 90)

	local verb
	if eventType == "join" then verb = " juntou-se a voce!"
	elseif eventType == "leave" then verb = " saiu do jogo."
	elseif eventType == "friended" then verb = " agora e seu amigo!"
	else verb = " nao e mais seu amigo." end

	notifStroke.Color = accentColor
	notifText.Text = targetPlayer.DisplayName .. verb
	notifSound.SoundId = isPositive and NOTIFICATION_SOUND_POSITIVE_ID or NOTIFICATION_SOUND_NEGATIVE_ID

	loadAvatarThumbnail(notifAvatar, targetPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)

	pcall(function() notifSound:Play() end)

	local slideIn = TweenService:Create(notifToast, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0.5, 0, 0, 16)})
	slideIn:Play()
	slideIn.Completed:Wait()

	task.wait(3.5)

	local slideOut = TweenService:Create(notifToast, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(0.5, 0, 0, -80)})
	slideOut:Play()
	slideOut.Completed:Wait()

	notifTweening = false
end

Players.PlayerAdded:Connect(function(newPlayer)
	if newPlayer == player then return end
	if checkIsFriend(newPlayer) then
		task.spawn(function() showFriendNotification(newPlayer, "join") end)
	end
end)

Players.PlayerRemoving:Connect(function(leavingPlayer)
	if leavingPlayer == player then return end
	if checkIsFriend(leavingPlayer) then
		task.spawn(function() showFriendNotification(leavingPlayer, "leave") end)
	end
	friendCache[leavingPlayer.UserId] = nil
end)

task.spawn(function()
	while true do
		task.wait(FRIEND_CHECK_INTERVAL)
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= player then
				local isFriendNow = checkIsFriend(plr)
				local wasFriend = friendCache[plr.UserId]

				if wasFriend ~= nil and wasFriend ~= isFriendNow then
					friendCache[plr.UserId] = isFriendNow
					if isFriendNow then
						task.spawn(function() showFriendNotification(plr, "friended") end)
					else
						task.spawn(function() showFriendNotification(plr, "unfriended") end)
					end
					refreshList()
				else
					friendCache[plr.UserId] = isFriendNow
				end
			end
		end
	end
end)
