local function addPortalEffects(parent)
	local attachment = Instance.new("Attachment", parent)
	local nebula = Instance.new("ParticleEmitter", attachment)
	nebula.Texture = "rbxassetid://6031302855"
	nebula.Color = ColorSequence.new(Color3.fromRGB(0, 0, 0), Color3.fromRGB(0, 255, 255))
	nebula.Lifetime = NumberRange.new(0.8, 1.2)
	nebula.Rate = 150
	nebula.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 5), NumberSequenceKeypoint.new(1, 0)})
	nebula.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(0.5, 0.4), NumberSequenceKeypoint.new(1, 1)})
	nebula.Speed = NumberRange.new(2, 5)
	nebula.RotSpeed = NumberRange.new(-50, 50)

	local lightning = Instance.new("ParticleEmitter", attachment)
	lightning.Texture = "rbxassetid://281983213"
	lightning.Rate = 20
	lightning.Size = NumberSequence.new(3)
	lightning.Lifetime = NumberRange.new(0.1, 0.2)
	lightning.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1)})
end

local function createRealisticPortal(pos, isFlat, duration)
	local container = Instance.new("Model", workspace)
	local baseCF = isFlat and (pos * CFrame.Angles(math.rad(90), 0, 0)) or (pos * CFrame.Angles(0, 0, math.rad(90)))
	local lifeTime = duration or 2.5

	local core = Instance.new("Part")
	core.Shape = Enum.PartType.Cylinder
	core.Color = Color3.new(0, 0, 0)
	core.Material = Enum.Material.Glass
	core.Size = Vector3.new(0.3, 0, 0)
	core.Anchored = true
	core.CanCollide = false
	core.CFrame = baseCF
	core.Parent = container

	local core2 = core:Clone()
	core2.CFrame = core.CFrame * CFrame.new(-0.15, 0, 0)
	core2.Parent = container

	local edge = Instance.new("Part")
	edge.Shape = Enum.PartType.Cylinder
	edge.Color = Color3.fromRGB(0, 255, 255)
	edge.Material = Enum.Material.Neon
	edge.Size = Vector3.new(0.1, 0, 0)
	edge.Anchored = true
	edge.CanCollide = false
	edge.CFrame = core.CFrame * CFrame.new(-0.05, 0, 0)
	edge.Parent = container

	local light = Instance.new("PointLight", edge)
	light.Color = Color3.fromRGB(0, 255, 255)
	light.Range = 25
	light.Brightness = 10
	addPortalEffects(edge)

	local info = TweenInfo.new(0.6, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out)
	TweenService:Create(core, info, {Size = Vector3.new(0.3, 8, 8)}):Play()
	TweenService:Create(core2, info, {Size = Vector3.new(0.3, 8, 8)}):Play()
	TweenService:Create(edge, info, {Size = Vector3.new(0.1, 8.8, 8.8)}):Play()

	local conn
	conn = RunService.Heartbeat:Connect(function()
		if not edge or not edge.Parent then
			conn:Disconnect()
			return
		end
		edge.CFrame = edge.CFrame * CFrame.new(0, 0, 0) * CFrame.Angles(math.rad(4), 0, 0)
		edge.Size = Vector3.new(0.1, 8.8 + math.sin(tick() * 20) * 0.2, 8.8 + math.sin(tick() * 20) * 0.2)
	end)

	task.delay(lifeTime, function()
		if container then
			if conn then
				conn:Disconnect()
			end
			local closeInfo = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In)
			TweenService:Create(core, closeInfo, {Size = Vector3.new(0.3, 0, 0)}):Play()
			TweenService:Create(core2, closeInfo, {Size = Vector3.new(0.3, 0, 0)}):Play()
			local t = TweenService:Create(edge, closeInfo, {Size = Vector3.new(0.1, 0, 0)})
			t:Play()
			t.Completed:Connect(function()
				container:Destroy()
			end)
		end
	end)
end

-- Teleport To com animacao completa de portal 3D
local isTeleportCooldown = false

teleportItem.MouseButton1Click:Connect(function()
	if not currentAboutTarget then return end
	if isTeleportCooldown then return end

	isTeleportCooldown = true

	-- SALVA o target ANTES de fechar o popup
	local target = currentAboutTarget
	closeAboutPopup()

	local targetChar = target.Character
	local myChar = player.Character
	if not targetChar or not myChar then
		isTeleportCooldown = false
		return
	end
	if not targetChar:FindFirstChild("HumanoidRootPart") or not myChar:FindFirstChild("HumanoidRootPart") then
		isTeleportCooldown = false
		return
	end

	local targetRoot = targetChar.HumanoidRootPart
	local myRoot = myChar.HumanoidRootPart

	-- Posicao de saida: atras do alvo
	local exitPos = targetRoot.CFrame * CFrame.new(0, 0, 3)
	local startPos = myRoot.CFrame

	-- ===== ANIMACAO DE TELEPORTE PORTAL MASTER =====

	-- 1. Cria portal de entrada (na posicao atual do jogador, em pe)
	createRealisticPortal(startPos * CFrame.new(0, 8.5, 0), false, 2.5)

	-- 2. Cria portal de saida (na posicao do alvo, em pe)
	createRealisticPortal(exitPos * CFrame.new(0, 8.5, 0), false, 2.5)

	-- 3. Toca som de teleporte
	playTeleportSound(1)

	-- 4. Desintegracao do personagem (encolhe e fica invisivel)
	local originalParts = {}
	for _, part in pairs(myChar:GetDescendants()) do
		if part:IsA("BasePart") then
			originalParts[part] = {
				Size = part.Size,
				Trans = part.Transparency,
				CanCollide = part.CanCollide
			}
			TweenService:Create(part, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
				Size = part.Size * Vector3.new(0.1, 10, 0.1),
				Transparency = 1
			}):Play()
			part.CanCollide = false
		end
	end

	-- 5. Aguarda animacao de desintegracao
	task.wait(0.6)

	-- 6. Teleporta para a posicao de saida
	if targetRoot.Parent and myRoot.Parent then
		myRoot.CFrame = exitPos
	end

	-- 7. Aguarda um frame para garantir posicao
	task.wait(0.1)

	-- 8. Reintegracao do personagem (volta ao tamanho normal e fica visivel)
	for part, data in pairs(originalParts) do
		if part and part.Parent then
			local targetTrans = (part.Name == "HumanoidRootPart") and 1 or data.Trans
			TweenService:Create(part, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
				Size = data.Size,
				Transparency = targetTrans
			}):Play()
			task.delay(0.6, function()
				if part and part.Parent then
					part.CanCollide = data.CanCollide
				end
			end)
		end
	end

	-- 9. Libera cooldown
	task.delay(1.5, function()
		isTeleportCooldown = false
	end)
end)

