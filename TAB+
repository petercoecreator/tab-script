-- ===================== TOGGLE (TAB) =====================

local isExpanded = false
local tweening = false

local function setExpanded(expanded)
	if tweening then return end
	tweening = true
	isExpanded = expanded

	local targetSize = expanded and EXPANDED_SIZE or MINIMIZED_SIZE
	local targetShadowTransparency = expanded and 0.45 or 1

	local tween = TweenService:Create(mainFrame, TweenInfo.new(TWEEN_TIME, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Size = targetSize })
	local shadowTween = TweenService:Create(shadow, TweenInfo.new(TWEEN_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { ImageTransparency = targetShadowTransparency })

	tween:Play()
	shadowTween:Play()
	tween.Completed:Connect(function()
		tweening = false
	end)
end

UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
	if gameProcessedEvent then return end
	if input.KeyCode == Enum.KeyCode.Tab then
		setExpanded(not isExpanded)
	end
end)

