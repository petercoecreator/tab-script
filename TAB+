local function checkAndCloseNativePlayerList()
	-- Verifica se o PlayerList nativo está visível/aberto no CoreGui
	local coreGui = game:GetService("CoreGui")
	local isNativeOpen = false

	pcall(function()
		-- Verifica se existe algum elemento do PlayerList nativo visível
		local playerList = coreGui:FindFirstChild("PlayerList") 
			or coreGui:FindFirstChild("PlayerListMaster")
			or coreGui:FindFirstChild("RoactPlayerList")

		if playerList then
			-- Verifica se está visível (Enabled ou Visible)
			if playerList:IsA("ScreenGui") and playerList.Enabled then
				isNativeOpen = true
			elseif playerList:IsA("Frame") and playerList.Visible then
				isNativeOpen = true
			elseif playerList:IsA("Folder") then
				-- Se for uma pasta, procura por ScreenGuis filhos visíveis
				for _, child in ipairs(playerList:GetDescendants()) do
					if child:IsA("ScreenGui") and child.Enabled then
						isNativeOpen = true
						break
					end
				end
			end
		end
	end)

	-- Se o PlayerList nativo estiver aberto, simula um pressionamento de TAB para fechar
