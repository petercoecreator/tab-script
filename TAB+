local isExpanded = false
local tweening = false

local function setExpanded(expanded)
	if tweening then return end
	tweening = true
	isExpanded = expanded

	local targetSize = expanded and EXPANDED_SIZE or MINIMIZED_SIZE
	local targetShadowTransparency = expanded and 0.45 or 1

	if not expanded then
		container.Visible = false
		searchBox.Visible = false
	end

	local tween = TweenService:Create(mainFrame, TweenInfo.new(TWEEN_TIME, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Size = targetSize })
	local shadowTween = TweenService:Create(shadow, TweenInfo.new(TWEEN_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { 
		ImageTransparency = targetShadowTransparency,
		Size = targetSize
	})

	tween:Play()
	shadowTween:Play()
	tween.Completed:Connect(function()
		tweening = false
		if expanded then
			container.Visible = true
			searchBox.Visible = true
		end
	end)
end

